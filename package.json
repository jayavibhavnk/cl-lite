{
  "name": "cl-lite",
  "version": "0.1.0",
  "description": "Lightweight Claude Code - minimal CLI agent with LLM tool-calling",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "cl-lite": "src/index.ts"
  },
  "scripts": {
